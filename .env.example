# ===================== 核心配置：存储模式选择 =====================
# 可选值：local(纯本地存储)/cloud(纯云端存储)/hybrid(混合存储)
STORAGE_MODE=local

# ===================== 大模型配置 =====================
# OpenAI兼容接口配置（通义千问、智谱AI等所有兼容OpenAI格式的接口均可使用）
LLM_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=你的大模型API密钥
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# 本地开源模型配置（使用Ollama时取消注释，注释上面的OpenAI配置）
# LLM_MODEL=qwen2:7b
# EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://localhost:11434

# ===================== 加密配置（云端存储必填，本地模式可选） =====================
# 自定义随机字符串，用于加密密钥生成
ENCRYPTION_SALT=your_custom_random_salt_here
# 自定义加密主密钥，务必妥善保管，丢失后无法解密云端数据
ENCRYPTION_PASSWORD=your_strong_encryption_password_here

# ===================== 云端存储配置（cloud/hybrid模式必填） =====================
# 兼容所有S3协议的存储：阿里云OSS、腾讯云COS、AWS S3、MinIO等
CLOUD_ACCESS_KEY=你的云存储AccessKey
CLOUD_SECRET_KEY=你的云存储SecretKey
CLOUD_ENDPOINT_URL=https://oss-cn-beijing.aliyuncs.com
CLOUD_REGION=oss-cn-beijing
CLOUD_BUCKET_NAME=your-brain-memory-bucket

# ===================== 记忆系统核心参数（无需修改，高级用户可调整） =====================
WORKING_MEMORY_MAX_TOKEN=4000
SHORT_TERM_MEMORY_DAYS=14
MEMORY_DECAY_RATE=0.1
RETRIEVAL_STRENGTH_BOOST=0.8
LOCAL_MEMORY_PATH=./local_memory_db
